# ==============================================
# BNR Stock Management - Environment Variables
# ==============================================


# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:8080/api

# ---- Server ----
SERVER_PORT=8080

# ---- Database Configuration ----
DB_URL=jdbc:postgresql://localhost:5432/bnr_stockdb
DB_USERNAME=postgres
DB_PASSWORD=gata04bazi
DB_DRIVER=org.postgresql.Driver

# ---- JPA / Hibernate ----
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ---- JWT Configuration ----
JWT_SECRET=mySecretKey12345678901234567890123456789012345678901234567890
JWT_EXPIRATION=86400000

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Logging ----
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=DEBUG
